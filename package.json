{
  "name": "dionysys-adaptive-ui",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "demos/excalidraw/frontend",
    "demos/excalidraw/backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build -w @dionysys/core -w @dionysys/client -w @dionysys/server -w @dionysys/react -w @dionysys/storage-mongodb -w @dionysys/connector-openai -w @dionysys/connector-gemini -w @dionysys/connector-anthropic --if-present && npm run build -w @dionysys-demo/excalidraw-frontend -w @dionysys-demo/excalidraw-backend --if-present",
    "build:packages": "npm run build -w @dionysys/core -w @dionysys/client -w @dionysys/server -w @dionysys/react -w @dionysys/storage-mongodb -w @dionysys/connector-openai -w @dionysys/connector-gemini -w @dionysys/connector-anthropic",
    "build:demo:backend": "npm run build --workspace=@dionysys-demo/excalidraw-backend",
    "build:demo:frontend": "npm run build --workspace=@dionysys-demo/excalidraw-frontend",
    "build:blog-preview": "node blog-current/build-preview.mjs",
    "build:blog-preview:watch": "node blog-current/build-preview.mjs --watch",
    "build:docs": "npm --prefix web-docs run build",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "start:demo:backend": "npm run start --workspace=@dionysys-demo/excalidraw-backend",
    "preview:demo:frontend": "npm run preview --workspace=@dionysys-demo/excalidraw-frontend",
    "docs": "npm --prefix web-docs run start",
    "docs:build": "npm --prefix web-docs run build",
    "docs:serve": "npm --prefix web-docs run serve",
    "docs:typecheck": "npm --prefix web-docs run typecheck",
    "pack:check": "node scripts/pack-check.mjs",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.7.3",
    "happy-dom": "^20.9.0"
  }
}
