{
  "name": "dionysys-adaptive-ui",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "docs": "cd web-docs && ./node_modules/.bin/docusaurus start",
    "docs:build": "cd web-docs && ./node_modules/.bin/docusaurus build",
    "docs:serve": "cd web-docs && ./node_modules/.bin/docusaurus serve",
    "docs:typecheck": "cd web-docs && ./node_modules/.bin/tsc"
  }
}
