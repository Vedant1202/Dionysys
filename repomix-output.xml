import type {
  AdminConsoleConfig,
  AdminConsoleOverview,
  PersonalityResource,
} from '@dionysys/core';

export type AdminConsoleTab = 'overview' | 'modes' | 'personalities' | 'calculations' | 'data' | 'apis' | 'export';

export interface AdminConsoleProps {
  apiBaseUrl?: string;
